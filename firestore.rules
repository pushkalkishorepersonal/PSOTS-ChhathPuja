rules_version = '2';

// ════════════════════════════════════════════════════
//  PSOTS Chhath Puja — Firestore Security Rules
//  Step 1: Profiles only
//
//  DEPLOY: firebase deploy --only firestore:rules
//  OR:     Firebase Console → Firestore → Rules tab → paste & publish
//
//  These rules are intentionally open for the initial rollout
//  because we are not yet using Firebase Auth (still on Google OAuth).
//  Step 2 will add Firebase Auth sign-in and tighten these rules.
// ════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Profiles ──────────────────────────────────────
    // Document ID = Google OAuth sub (a large opaque numeric string,
    // not publicly guessable). Any client that knows the UID can read/write.
    // Step 2 upgrade: allow read, write: if request.auth != null && request.auth.uid == uid;
    match /profiles/{uid} {
      allow read, write: if true;
    }

    // ── Contributions ──────────────────────────────────
    // Historical + current year contributions indexed by flat number.
    // Readable by anyone (flat numbers are not secret).
    // Writable by anyone for now — Step 2 will restrict to admin + owner.
    match /contributions/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Everything else — locked until later migration steps ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
