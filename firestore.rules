rules_version = '2';

// ════════════════════════════════════════════════════
//  PSOTS Chhath Puja — Firestore Security Rules
//
//  Step 2: Firebase Auth is now active.
//  - Profiles locked to owner (request.auth.uid == uid)
//  - Contributions: create requires auth, admin-only update/delete
//  - Admin-only collections: announcements, config, finance, receipts, residents
//
//  DEPLOY: firebase deploy --only firestore:rules
//  OR:     Firebase Console → Firestore → Rules tab → paste & publish
// ════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Shared helpers ─────────────────────────────────

    function isNonEmpty(val) {
      return val != null && val != '';
    }

    // Checks Firebase Auth token email against admin list.
    // Add additional admin emails to the list as needed.
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email in [
               'pushkalkishore@gmail.com'
             ];
    }

    function isValidContribution(data) {
      return data.keys().hasAll(['flat', 'year', 'amount', 'status'])
          && isNonEmpty(data.flat)
          && data.year is int
          && data.amount is number
          && data.amount > 0
          && data.amount < 1000000  // sanity cap: ₹10 lakh max
          && isNonEmpty(data.status);
    }

    // ── Profiles ──────────────────────────────────────
    // Document ID = Firebase Auth UID.
    // Read: only the owning user (or admin).
    // Write: only the owning user (or admin).
    match /profiles/{uid} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // ── Contributions ──────────────────────────────────
    // Read: any signed-in user may read contributions.
    // Create: any signed-in user may submit a new pending contribution with valid fields.
    // Update/Delete: admin only (for verify / reject / cleanup).
    match /contributions/{docId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && isValidContribution(request.resource.data)
                    && request.resource.data.status == 'Pending Verification';

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Residents directory ─────────────────────────────
    // Read: any signed-in user.
    // Write: admin only.
    match /residents/{flat} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Announcements ───────────────────────────────────
    // Read: public (unauthenticated visitors can see announcements).
    // Write: admin only.
    match /announcements/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Site Config ─────────────────────────────────────
    // Read: public (JS needs config values like upiId on page load).
    // Write: admin only.
    match /config/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Finance ─────────────────────────────────────────
    // Read: public (finance page shows summary publicly).
    // Write: admin only.
    match /finance/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Receipts ────────────────────────────────────────
    // Read: signed-in users only (contains expense details).
    // Write: admin only.
    match /receipts/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Volunteers ───────────────────────────────────────
    // Create: any signed-in user (submit their own nomination).
    // Read:   public (volunteer wall is visible to everyone).
    // Update/Delete: admin only (toggle visibility, remove entries).
    match /volunteers/{docId} {
      allow read:   if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['name','flat','year'])
                    && isNonEmpty(request.resource.data.name)
                    && isNonEmpty(request.resource.data.flat);
      allow update, delete: if isAdmin();
    }

    // ── Meta (receipt counters, internal bookkeeping) ────
    // Read/Write: admin only (receipt sequence must not be tampered with).
    // Exception: signed-in users may READ the counter doc so the client-side
    // Firestore fallback in getNextReceiptNo() can run a transaction.
    match /meta/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null; // transaction runs client-side under auth
    }

    // ── Everything else — locked ─────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
