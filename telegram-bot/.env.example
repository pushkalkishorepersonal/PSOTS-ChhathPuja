# ── Required ───────────────────────────────────────────────────────────────────
# Your Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# ── Recommended ────────────────────────────────────────────────────────────────
# Gemini API key for AI-based detection (free tier)
# Get it at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Your Telegram user ID(s) — comma-separated (get yours from @userinfobot)
# These users can use admin commands (/stats, /reset, /allow) even if not group admin
ADMIN_IDS=123456789,987654321

# ── Render.com (only needed for production deployment) ─────────────────────────
# Set RENDER=true and WEBHOOK_URL to your Render app URL when deploying
RENDER=false
WEBHOOK_URL=https://psots-society-bot.onrender.com

# Port for the Flask webhook server (Render sets this automatically)
PORT=8080
